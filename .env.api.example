# .env.api
# Loaded into the hummingbot-api AND dashboard containers via env_file.
# Copy this file to .env.api on the Hetzner server and replace the placeholders
# with strong random passwords. .env.api is gitignored — never commit real values.

# === API basic-auth ===
# Used by hummingbot-api as the credentials it requires from clients.
USERNAME=admin
PASSWORD=changeme-strong-random

# Same credentials, named for the dashboard's environment variables.
# Dashboard reads these to call the API. Must match USERNAME / PASSWORD above.
BACKEND_API_USERNAME=admin
BACKEND_API_PASSWORD=changeme-strong-random

# === Encryption for stored bot credentials ===
# DON'T LOSE THIS — re-creating the API requires re-adding all exchange API keys.
# Save in your password manager separately from the auth password above.
CONFIG_PASSWORD=changeme-strong-random

# === Optional: Hummingbot Gateway (DEX) ===
# Leave default until we wire Gateway in (Phase 7+).
GATEWAY_URL=http://host.docker.internal:15888
