# .env.api
# Used by the hummingbot-api service (and dashboard via $API_USERNAME / $API_PASSWORD).
# Copy this file to .env.api on the Hetzner server and replace the values.
# .env.api is gitignored — never commit real credentials.

# API basic-auth — used by both hummingbot-api and the Streamlit dashboard.
# Generate strong random values, save in your password manager.
USERNAME=admin
PASSWORD=changeme-strong-random
API_USERNAME=admin
API_PASSWORD=changeme-strong-random

# Encrypts bot credentials saved through the API.
# DON'T LOSE THIS — re-creating the API will require you to re-add all bot keys.
CONFIG_PASSWORD=changeme-strong-random

# Optional: GATEWAY_URL for DEX trading via Hummingbot Gateway (Phase 7+).
# Leave default until we wire Gateway in.
GATEWAY_URL=http://host.docker.internal:15888
